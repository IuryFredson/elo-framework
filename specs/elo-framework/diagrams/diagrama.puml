' =======================================================================
'  HERANCAS / REALIZACOES  ->  ELO-CORE
' =======================================================================
' --- apto realiza/estende o dominio do framework ---
apto_Anuncio ..|> elo_Oferta
apto_Denuncia ..|> elo_Denuncia
apto_Manifestacao ..|> elo_Manifestacao
apto_PerfilConvivencia ..|> elo_Perfil
apto_Criterio ..|> elo_CriterioDenuncia
apto_Locador --|> elo_Usuario
apto_Universitario --|> elo_Usuario
apto_AnuncioService --|> elo_OfertaService
apto_LocadorService --|> elo_UsuarioService
apto_UniversitarioService --|> elo_UsuarioService
apto_DenunciaService --|> elo_DenunciaService
apto_ManifService --|> elo_ManifestacaoService
apto_ModeracaoService --|> elo_ModeracaoService
apto_PerfilService --|> elo_PerfilService
apto_MatchmakingService --|> elo_MatchingService
apto_CompatDet ..|> elo_CompatStrategy
apto_LlmProvider --|> elo_AbstractLlmProvider
apto_GroqClient --|> elo_AbstractGroqClient
apto_GroqProps ..|> elo_GroqProps
apto_LlmParser --|> elo_JsonParser
apto_PromptBuilder ..|> elo_PromptBuilder

' --- apto estende a camada REST generica do framework ---
apto_AnuncioController --|> elo_OfertaController
apto_DenunciaController --|> elo_DenunciaController
apto_LocadorController --|> elo_UsuarioController
apto_UniversitarioController --|> elo_UsuarioController
apto_ManifController --|> elo_ManifestacaoController
apto_MatchmakingController --|> elo_MatchingController
apto_ModeracaoController --|> elo_ModeracaoController
apto_PerfilController --|> elo_PerfilController

' =======================================================================
'  ASSOCIACOES DE DOMINIO - APTO
' =======================================================================
apto_Anuncio "*" --> "1" apto_PerfilAnunciante : anunciante
apto_Anuncio "1" --> "1" apto_Moradia : moradia
apto_Anuncio --> apto_TipoAnuncio
apto_Anuncio --> apto_StatusAnuncio
apto_Avaliacao "*" --> "1" apto_Universitario : avaliador
apto_Avaliacao "*" --> "1" apto_PerfilAnunciante : avaliado
apto_Avaliacao "*" --> "1" apto_Anuncio
apto_Avaliacao "*" --> "1" apto_Moradia
apto_Denuncia "*" --> "1" elo_Usuario : denunciante
apto_Denuncia "*" --> "1" apto_Anuncio
apto_Denuncia --> apto_Criterio
apto_Denuncia --> elo_StatusDenuncia
apto_Locador "1" --> "1" apto_PerfilAnunciante
apto_Manifestacao "*" --> "1" apto_Anuncio
apto_Manifestacao "*" --> "1" apto_Universitario : interessado
apto_Manifestacao --> elo_StatusManifestacao
apto_Moradia --> apto_TipoMoradia
apto_PerfilAnunciante "1" --> "1" elo_Usuario
apto_Reputacao "1" --> "1" apto_PerfilAnunciante
apto_Universitario "1" --> "0..1" apto_PerfilConvivencia
apto_Universitario "1" --> "0..1" apto_PerfilAnunciante
apto_Universitario --> apto_Genero
apto_PerfilConvivencia --> apto_HorarioSono
apto_PerfilConvivencia --> apto_NivelBarulho
apto_PerfilConvivencia --> apto_FreqVisitas
apto_PerfilConvivencia --> apto_NivelOrg
apto_PerfilConvivencia --> apto_RotinaEstudos
apto_PerfilConvivencia --> apto_PrefGenero

' ---- controllers apto delegam para os services ----
apto_AnuncioController ..> apto_AnuncioService
apto_DenunciaController ..> apto_DenunciaService
apto_LocadorController ..> apto_LocadorService
apto_UniversitarioController ..> apto_UniversitarioService
apto_ManifController ..> apto_ManifService
apto_MatchmakingController ..> apto_MatchmakingService
apto_ModeracaoController ..> apto_ModeracaoService
apto_PerfilController ..> apto_PerfilService
apto_AvaliacaoController ..> apto_AvaliacaoService
apto_MoradiaController ..> apto_MoradiaService
apto_PerfilAnuncianteController ..> apto_PerfilAnuncianteService
apto_ReputacaoController ..> apto_ReputacaoService
apto_DiagnosticoController ..> apto_GroqClient

' ---- colaboracoes entre services (apto) ----
apto_AnuncioService ..> apto_ManifService
apto_AvaliacaoService ..> apto_AnuncioService
apto_AvaliacaoService ..> apto_ReputacaoService
apto_ModeracaoService ..> apto_ManifService
apto_ModeracaoService ..> apto_AcaoModeracao
apto_MatchmakingService ..> apto_CompatDet
apto_MatchmakingService ..> apto_LlmProvider
apto_MatchmakingService ..> apto_ResultadoCompat
apto_LlmProvider ..> apto_GroqClient
apto_LlmProvider ..> apto_PromptBuilder
apto_LlmProvider ..> apto_LlmParser
apto_ResultadoCompat --> apto_OrigemCompat
apto_ResultadoCompat ..> elo_ResultadoCompat : adapta
apto_GroqClient ..> apto_GroqProps


note top of apto_AvaliacaoController
  Controllers sem par generico no framework
  (Avaliacao, Moradia, PerfilAnunciante,
  Reputacao, DiagnosticoGroq) sao REST puros
  da instancia, nao estendem a camada elo > web
end note

legend right
  <b>elo-framework (elo-core + apto)</b>
  elo-core = nucleo generico (Template Method + Strategy)
  apto = instancia que estende/realiza o nucleo
  camada REST: controllers apto estendem os RestController genericos
  --|>  heranca    ..|>  realizacao    -->  associacao    ..>  dependencia
endlegend

@enduml