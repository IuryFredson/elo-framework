@startuml
title Elo Framework - Apto como Instancia (organizado)

left to right direction
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam shadowing false

' ============================================================
' 1. FRAMEWORK CORE (BIBLIOTECA PURA)
' ============================================================
package "elo-core (com.elo) <<framework>>" {

  interface PerfilFramework <<ponto flexivel>> {
    +tipoPerfil(): String
  }
    
  enum STATUS_INTERACAO <<contrato fixo>> {
    ATIVO,
    PAUSADO,
    ENCERRADO
  }

  interface OfertaFramework <<ponto flexivel>> {
    +getId(): UUID
    +getPublicadorId(): UUID
    +tipoOferta(): String
    +isAtiva(): boolean
  }

  interface InteracaoFramework <<ponto fixo>> {
    +getId(): UUID
    +getInteressadoId(): UUID
    +getOfertaId(): UUID
    +tipoFixo(): String
    +getStatus(): STATUS_INTERACAO
  }


  class ResultadoCompatibilidade <<ponto fixo>> {
    +percentual: int
    +justificativa: String
    +criteriosAtendidos: List<String>
  }

  interface CompatibilidadeStrategy<P extends PerfilFramework> <<ponto flexivel>> {
    +calcular(solicitante: P, candidato: P): ResultadoCompatibilidade
  }

  class CompatibilidadeService<P extends PerfilFramework> <<ponto fixo>> {
    -strategy: CompatibilidadeStrategy<P>
    -elegibilidade: BiPredicate<P>

    +calcularCompatibilidades(
      solicitante: P,
      candidatos: List<P>,
      topN: int
    ): List<ResultadoCompatibilidade>
  }

  CompatibilidadeService o--> CompatibilidadeStrategy
  CompatibilidadeService ..> ResultadoCompatibilidade
}

' ============================================================
' 2. IMPLEMENTAÇÕES DO APTO (DOMÍNIO)
' ============================================================
package "apto (com.apto) <<instancia>> - dominio" {

  abstract class Usuario {
    -id: UUID
    -nome: String
    -email: String
    -telefone: String
    -ativo: boolean
  }

  class UsuarioUniversitario {
    -emailInstitucional: String
    -curso: String
    -dataNascimento: LocalDate
    -genero: Genero

    +isAnunciante(): boolean
  }

  class Locador {
    -documentoIdentificacao: String
    -nomeExibicaoOuRazao: String
  }

  class PerfilAnunciante {
    -id: UUID
    -ativo: boolean
  }

  class PerfilConvivencia {
    -id: UUID
    -horarioSono: HorarioSono
    -nivelBarulhoAceitavel: NivelBarulho
    -frequenciaVisitas: FrequenciaVisitas
    -nivelOrganizacao: NivelOrganizacao
    -rotinaEstudos: RotinaEstudos
    -consomeAlcool: Boolean
    -fumante: Boolean
    -aceitaAnimais: Boolean
    -preferenciaGeneroConvivencia: PreferenciaGeneroConvivencia
    -descricaoLivre: String

    +tipoPerfil(): String
  }

  class Anuncio {
    -id: UUID
    -titulo: String
    -descricao: String
    -valorMensal: BigDecimal
    -tipoAnuncio: TipoAnuncio
    -status: StatusAnuncio
    -dataPublicacao: LocalDate

    +tipoOferta(): String
    +getPublicadorId(): UUID
    +isAtiva(): boolean
  }

  class Moradia {
    -id: UUID
    -tipoMoradia: TipoMoradia
    -bairro: String
    -enderecoResumo: String
    -mobiliado: boolean
    -aceitaAnimais: boolean
    -quantidadeVagas: int
    -regrasMoradia: String
  }

  class ManifestacaoInteresse {
    -id: UUID
    -status: StatusManifestacaoInteresse
    -mensagem: String
    -dataManifestacao: LocalDateTime
    -dataResposta: LocalDateTime

    +tipoFixo(): String
  }

  enum OrigemCompatibilidade {
    LLM
    FALLBACK_DETERMINISTICO
  }

  class CompatibilidadeDeterministicaCalculator {
    +calcular(
      solicitante: PerfilConvivencia,
      candidato: PerfilConvivencia
    ): ResultadoCompatibilidade
  }

  class ElegibilidadeGeneroPolicy {
    +compativel(
      solicitante: UsuarioUniversitario,
      candidato: UsuarioUniversitario
    ): boolean
  }
}

' ============================================================
' 3. ORQUESTRADOR (SERVIÇO DE APLICAÇÃO)
' ============================================================
package "apto (com.apto) <<instancia>> - orquestracao" {

  class MatchmakingService {
    -compatibilidadeService: CompatibilidadeService<PerfilConvivencia>
    -elegibilidadeGenero: ElegibilidadeGeneroPolicy
    -groqClient: GroqClient

    +buscarColegasCompativeis(
      solicitanteId: UUID,
      topN: int
    ): MatchmakingResponseDTO
  }
}

' ============================================================
' RELAÇÕES DO DOMÍNIO
' ============================================================
Usuario <|-- UsuarioUniversitario
Usuario <|-- Locador

UsuarioUniversitario "1" -- "0..1" PerfilConvivencia : possui
Usuario "1" -- "0..1" PerfilAnunciante
PerfilAnunciante "1" -- "0..*" Anuncio
Anuncio "1" -- "1" Moradia

UsuarioUniversitario "1" -- "0..*" ManifestacaoInteresse
ManifestacaoInteresse "0..*" -- "1" Anuncio

' ============================================================
' IMPLEMENTAÇÃO DO FRAMEWORK
' ============================================================
PerfilFramework <|.. PerfilConvivencia
OfertaFramework <|.. Anuncio
InteracaoFramework <|.. ManifestacaoInteresse
CompatibilidadeStrategy <|.. CompatibilidadeDeterministicaCalculator

' ============================================================
' FLUXO
' ============================================================
MatchmakingService --> CompatibilidadeService
CompatibilidadeService o--> CompatibilidadeStrategy
CompatibilidadeService ..> ResultadoCompatibilidade

MatchmakingService --> ElegibilidadeGeneroPolicy
MatchmakingService ..> OrigemCompatibilidade

@enduml